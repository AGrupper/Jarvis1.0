# === Anthropic (Claude API) ===
ANTHROPIC_API_KEY=sk-ant-...

# === Notion ===
NOTION_TOKEN=secret_...
NOTION_BRIEFING_DB_ID=your-32-char-database-id-for-daily-briefings
NOTION_SESSION_DB_ID=your-32-char-database-id-for-session-debriefs
NOTION_SESSION_START_DB_ID=your-32-char-database-id-for-session-starts

# === Todoist ===
TODOIST_API_TOKEN=your-todoist-api-token

# === GitHub ===
GITHUB_TOKEN=ghp_...
GITHUB_REPOS=owner/repo1,owner/repo2

# === Google OAuth2 (Gmail + Calendar) ===
# Download credentials.json from Google Cloud Console and place in agent/ root.
# token.json is auto-generated on first run after OAuth consent.
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json
